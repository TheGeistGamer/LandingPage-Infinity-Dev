---
import {
	NavBar,
	Hero,
	LandingInteractions,
	CTA,
	Faq,
	Footer,
	Process,
	Services,
	Stats,
	Work,
} from "../components";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<!-- ===== NAV ===== -->
	<NavBar client:only="react" />

	<a id="top"></a>

	<!-- ===== HERO ===== -->
	<Hero client:only="react" />

	<!-- ===== STATS ===== -->
	<Stats client:only="react" />

	<!-- ===== SERVICES ===== -->
	<Services client:only="react" />

	<!-- ===== PROCESS ===== -->
	<Process client:only="react" />

	<!-- ===== WORK ===== -->
	<Work client:only="react" />

	<!-- ===== FAQ ===== -->
	<Faq client:only="react" />

	<!-- ===== CONTACT / CTA ===== -->
	<CTA client:only="react" />

	<!-- ===== FOOTER ===== -->
	<Footer client:only="react" />

	<LandingInteractions client:only="react" />
</Layout>
